generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                    Int                    @id @default(autoincrement())
  nombre                String
  cuit                  String                 @unique
  direccion             String?
  telefono              String?
  email                 String?
  logo                  String?
  monedaId              Int
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  createdBy             String?
  updatedBy             String?
  centrosCosto          CentroCosto[]
  cuentas               Cuenta[]
  documentosClientes    DocumentoClientes[]
  documentosProveedores DocumentoProveedores[]
  ejercicios            Ejercicio[]
  moneda                Moneda                 @relation("EmpresaMoneda", fields: [monedaId], references: [id], onUpdate: NoAction)
  usuarios              EmpresaUsuario[]
  entidades             Entidad[]
  facturasDocentes      FacturaDocente[]
  gestionesPago         GestionPago[]
  mediosPago            MedioPago[]
  pagos                 Pagos[]
  pedidosPagos          PedidosPagos[]
  serviciosConfig       ServicioConfig[]
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String?          @unique
  password      String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String?
  updatedBy     String?
  accounts      Account[]
  empresas      EmpresaUsuario[]
  sessions      Session[]
  roles         UserRole[]
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String?
  updatedBy   String?
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String?
  updatedBy   String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model EmpresaUsuario {
  empresaId Int
  userId    String
  role      String?
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([empresaId, userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Ejercicio {
  id            Int            @id @default(autoincrement())
  numero        Int
  inicio        DateTime
  fin           DateTime
  cerrado       Boolean        @default(false)
  empresaId     Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?
  updatedBy     String?
  asientos      Asiento[]
  cuentas       Cuenta[]
  empresa       Empresa        @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  gestionesPago GestionPago[]
  pagos         Pagos[]
  pedidosPagos  PedidosPagos[]
  docProveedores DocumentoProveedores[]
  docClientes    DocumentoClientes[]

  @@unique([numero, empresaId])
}

model Cuenta {
  id                    Int                 @id @default(autoincrement())
  codigo                String
  codigoCorto           Int?
  nombre                String
  tipo                  String
  padreId               Int?
  empresaId             Int
  ejercicioId           Int
  imputable             Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  createdBy             String?
  updatedBy             String?
  centrosCosto          CentroCostoCuenta[]
  ejercicio             Ejercicio           @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa               Empresa             @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  padre                 Cuenta?             @relation("Jerarquia", fields: [padreId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  hijos                 Cuenta[]            @relation("Jerarquia")
  facturasDocentes      FacturaDocente[]
  mediosPago            MedioPago[]
  renglones             RenglonAsiento[]
  serviciosDeptoImputar ServicioConfig[]    @relation("CuentaDeptoImputar")
  serviciosDeptoRetener ServicioConfig[]    @relation("CuentaDeptoRetener")
  serviciosFundImputar  ServicioConfig[]    @relation("CuentaFundacionImputar")
  serviciosFundRetener  ServicioConfig[]    @relation("CuentaFundacionRetener")
  serviciosIngresos     ServicioConfig[]    @relation("CuentaIngresos")

  @@unique([codigo, ejercicioId])
}

model Asiento {
  id                 Int                    @id @default(autoincrement())
  numero             Int
  fecha              DateTime
  descripcion        String
  ejercicioId        Int
  anulaAId           Int?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdBy          String?
  updatedBy          String?
  anulaA             Asiento?               @relation("Reversion", fields: [anulaAId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  anulaciones        Asiento[]              @relation("Reversion")
  ejercicio          Ejercicio              @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  docClientes        DocumentoClientes[]    @relation("AsientoADocumentoCli")
  documentos         DocumentoProveedores[] @relation("AsientoADocumentoProv")
  facturasDocentes   FacturaDocente[]
  anulacionesGestion GestionPago[]          @relation("AsientoDeAnulacion")
  pagosGestion       GestionPago[]          @relation("AsientoDePago")
  pagos              Pagos[]
  renglones          RenglonAsiento[]
}

model RenglonAsiento {
  id         Int      @id @default(autoincrement())
  debe       Decimal  @default(0) @db.Decimal(18, 2)
  haber      Decimal  @default(0) @db.Decimal(18, 2)
  leyenda    String?
  cuentaId   Int
  asientoId  Int
  monedaId   Int
  cotizacion Decimal  @db.Decimal(18, 4)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
  asiento    Asiento  @relation(fields: [asientoId], references: [id], onUpdate: NoAction)
  cuenta     Cuenta   @relation(fields: [cuentaId], references: [id], onUpdate: NoAction)
  moneda     Moneda   @relation("MonedaRenglones", fields: [monedaId], references: [id], onUpdate: NoAction)
}

model Entidad {
  id                 Int                    @id @default(autoincrement())
  nombre             String
  cuit               String?
  tipoId             Int
  empresaId          Int
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  createdBy          String?
  updatedBy          String?
  email              String?
  nroDoc             String?
  condicionIva       Int?
  telefono           String?
  documentosClientes DocumentoClientes[]
  documentos         DocumentoProveedores[]
  empresa            Empresa                @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  tipo               TipoEntidad            @relation(fields: [tipoId], references: [id], onUpdate: NoAction)
  facturasDocentes   FacturaDocente[]
  pagosGestion       GestionPago[]
}

model DocumentoProveedores {
  id          Int       @id @default(autoincrement())
  tipo        String
  numero      String
  fecha       DateTime
  montoTotal  Decimal   @db.Decimal(18, 2)
  iva         Decimal   @db.Decimal(18, 2)
  entidadId   Int
  empresaId   Int
  ejercicioId Int
  asientoId   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  asiento     Asiento?  @relation("AsientoADocumentoProv", fields: [asientoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ejercicio   Ejercicio @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  entidad     Entidad   @relation(fields: [entidadId], references: [id], onUpdate: NoAction)
}

model DocumentoClientes {
  id          Int                     @id @default(autoincrement())
  tipo        String
  numero      String
  fecha       DateTime
  montoTotal  Decimal                 @db.Decimal(18, 2)
  iva         Decimal                 @db.Decimal(18, 2)
  entidadId   Int
  empresaId   Int
  ejercicioId Int
  asientoId   Int?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  createdBy   String?
  updatedBy   String?
  rubroId     Int?
  servicioId  Int?
  fechaPago   DateTime?
  montoPagado Decimal?                @db.Decimal(18, 2)
  cae         String?                 @db.NVarChar(20)
  caeVto      DateTime?
  afipEstado  String?                 @db.NVarChar(20)
  pagos360Id  BigInt?
  pagos360Url String?                 @db.NVarChar(500)
  pagos360Estado String?              @db.NVarChar(50)
  items       DocumentoClientesItem[]
  asiento     Asiento?                @relation("AsientoADocumentoCli", fields: [asientoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ejercicio   Ejercicio               @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa     Empresa                 @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  entidad     Entidad                 @relation(fields: [entidadId], references: [id], onUpdate: NoAction)
  rubro       Rubro?                  @relation(fields: [rubroId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  servicio    Servicio?               @relation(fields: [servicioId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model DocumentoClientesItem {
  id                 Int               @id @default(autoincrement())
  documentoClienteId Int
  descripcion        String            @db.NVarChar(4000)
  cantidad           Decimal           @db.Decimal(18, 4)
  precioUnitario     Decimal           @db.Decimal(18, 2)
  importeTotal       Decimal           @db.Decimal(18, 2)
  documento          DocumentoClientes @relation(fields: [documentoClienteId], references: [id], onDelete: Cascade)

  @@map("documento_clientes_items")
}

model PedidosPagos {
  id                Int       @id @default(autoincrement())
  ejercicioId       Int
  empresaId         Int
  tipo              String
  fechaPedido       DateTime
  totalPedido       Decimal   @db.Decimal(18, 2)
  concepto          String
  solicitadoPor     String
  anulado           Boolean   @default(false)
  fechaAnulacion    DateTime?
  anuladoPor        String?
  autorizado        Boolean   @default(false)
  fechaAutorizacion DateTime?
  autorizadoPor     String?
  nroPago           Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  updatedBy         String?
  pagos             Pagos[]
  ejercicio         Ejercicio @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa           Empresa   @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
}

model Pagos {
  id             Int          @id @default(autoincrement())
  ejercicioId    Int
  empresaId      Int
  pedidoId       Int
  fechaPago      DateTime
  importeBruto   Decimal      @db.Decimal(18, 2)
  importeNeto    Decimal      @db.Decimal(18, 2)
  asientoId      Int?
  formaPagoId    Int
  beneficiarioId String?
  descripcion    String?
  concepto       String
  anulado        Boolean      @default(false)
  fechaAnulacion DateTime?
  anuladoPor     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      String?
  updatedBy      String?
  asiento        Asiento?     @relation(fields: [asientoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ejercicio      Ejercicio    @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa        Empresa      @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  formaPago      FormaPago    @relation(fields: [formaPagoId], references: [id], onUpdate: NoAction)
  pedido         PedidosPagos @relation(fields: [pedidoId], references: [id], onUpdate: NoAction)
}

model FormaPago {
  id        Int      @id @default(autoincrement())
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  pagos     Pagos[]
}

model Moneda {
  id           Int              @id @default(autoincrement())
  codigo       String           @unique
  nombre       String
  simbolo      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  createdBy    String?
  updatedBy    String?
  cotizaciones Cotizacion[]
  empresas     Empresa[]        @relation("EmpresaMoneda")
  renglones    RenglonAsiento[] @relation("MonedaRenglones")
}

model Cotizacion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime
  valor     Decimal  @db.Decimal(18, 4)
  monedaId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  moneda    Moneda   @relation(fields: [monedaId], references: [id], onUpdate: NoAction)

  @@unique([fecha, monedaId])
}

model TipoEntidad {
  id        Int       @id @default(autoincrement())
  nombre    String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  entidades Entidad[]
}

model Factura {
  id                   Int                @id @default(autoincrement())
  tipoComprobante      String             @map("tipo_comprobante") @db.NVarChar(10)
  codComprobante       String?            @map("cod_comprobante") @db.NVarChar(10)
  puntoVenta           String             @map("punto_venta") @db.NVarChar(10)
  numeroComprobante    String             @map("numero_comprobante") @db.NVarChar(20)
  fechaEmision         DateTime           @map("fecha_emision") @db.Date
  fechaVtoPago         DateTime?          @map("fecha_vto_pago") @db.Date
  periodoDesde         DateTime?          @map("periodo_desde") @db.Date
  periodoHasta         DateTime?          @map("periodo_hasta") @db.Date
  condicionVenta       String?            @map("condicion_venta") @db.NVarChar(50)
  caeNumero            String?            @map("cae_numero") @db.NVarChar(30)
  caeVto               DateTime?          @map("cae_vto") @db.Date
  razonSocialEmisor    String             @map("razon_social_emisor") @db.NVarChar(200)
  cuitEmisor           String             @map("cuit_emisor") @db.NVarChar(20)
  domicilioEmisor      String?            @map("domicilio_emisor") @db.NVarChar(300)
  ingresosBrutos       String?            @map("ingresos_brutos") @db.NVarChar(50)
  condicionIvaEmisor   String?            @map("condicion_iva_emisor") @db.NVarChar(100)
  inicioActividades    DateTime?          @map("inicio_actividades") @db.Date
  razonSocialReceptor  String?            @map("razon_social_receptor") @db.NVarChar(200)
  cuitReceptor         String?            @map("cuit_receptor") @db.NVarChar(20)
  domicilioReceptor    String?            @map("domicilio_receptor") @db.NVarChar(300)
  condicionIvaReceptor String?            @map("condicion_iva_receptor") @db.NVarChar(100)
  subtotal             Decimal            @default(0) @db.Decimal(18, 2)
  otrosTributos        Decimal            @default(0) @map("otros_tributos") @db.Decimal(18, 2)
  importeTotal         Decimal            @default(0) @map("importe_total") @db.Decimal(18, 2)
  archivoOrigen        String             @map("archivo_origen") @db.NVarChar(500)
  hashArchivo          String?            @map("hash_archivo") @db.NVarChar(64)
  procesadoEn          DateTime           @default(now()) @map("procesado_en")
  estado               String             @default("ok") @db.NVarChar(20)
  observaciones        String?            @db.NVarChar(4000)
  createdAt            DateTime           @default(now())
  createdBy            String?
  updatedAt            DateTime           @updatedAt
  updatedBy            String?
  items                FacturaItem[]
  logs                 LogProcesamiento[]

  @@unique([cuitEmisor, puntoVenta, numeroComprobante, tipoComprobante], name: "UQ_factura")
  @@map("facturas")
}

model FacturaItem {
  id              Int      @id @default(autoincrement())
  facturaId       Int      @map("factura_id")
  codigo          String?  @db.NVarChar(50)
  descripcion     String?  @db.NVarChar(4000)
  cantidad        Decimal? @db.Decimal(18, 4)
  unidadMedida    String?  @map("unidad_medida") @db.NVarChar(50)
  precioUnitario  Decimal? @map("precio_unitario") @db.Decimal(18, 2)
  bonificacionPct Decimal? @default(0) @map("bonificacion_pct") @db.Decimal(5, 2)
  importeBonif    Decimal? @default(0) @map("importe_bonif") @db.Decimal(18, 2)
  subtotal        Decimal? @db.Decimal(18, 2)
  createdAt       DateTime @default(now())
  createdBy       String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?
  factura         Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@map("factura_items")
}

model LogProcesamiento {
  id        Int      @id @default(autoincrement())
  archivo   String   @db.NVarChar(500)
  evento    String   @db.NVarChar(50)
  detalle   String?  @db.NVarChar(4000)
  facturaId Int?     @map("factura_id")
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  factura   Factura? @relation(fields: [facturaId], references: [id])

  @@map("log_procesamiento")
}

model FacturaDocente {
  id                    Int          @id @default(autoincrement())
  entidadId             Int
  puntoVenta            String       @db.NVarChar(5)
  numero                String       @db.NVarChar(8)
  fecha                 DateTime     @db.Date
  importe               Decimal      @db.Decimal(18, 2)
  anioHonorarios        Int
  mesHonorarios         Int
  cuentaGastosId        Int
  observaciones         String?      @db.NVarChar(4000)
  asientoPagoId         Int?
  empresaId             Int
  createdAt             DateTime     @default(now(), map: "DF__FacturaDo__creat__4A4E069C")
  updatedAt             DateTime     @updatedAt
  createdBy             String?
  updatedBy             String?
  estado                String       @default("Autorizacion Pendiente") @db.NVarChar(30)
  fechaAutorizado       DateTime?
  usuarioAutorizado     String?      @db.NVarChar(100)
  fechaHabilitacionPago DateTime?    @db.Date
  gestionPagoId         Int?
  asientoPago           Asiento?     @relation(fields: [asientoPagoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuentaGastos          Cuenta       @relation(fields: [cuentaGastosId], references: [id], onUpdate: NoAction)
  empresa               Empresa      @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  entidad               Entidad      @relation(fields: [entidadId], references: [id], onUpdate: NoAction)
  gestionPago           GestionPago? @relation(fields: [gestionPagoId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([entidadId, puntoVenta, numero], name: "UQ_DocenteFactura")
}

model MedioPago {
  id        Int           @id @default(autoincrement())
  nombre    String
  cuentaId  Int?
  empresaId Int
  createdAt DateTime      @default(now(), map: "DF__MedioPago__creat__51EF2864")
  updatedAt DateTime      @updatedAt
  createdBy String?
  updatedBy String?
  pagos     GestionPago[]
  cuenta    Cuenta?       @relation(fields: [cuentaId], references: [id], onUpdate: NoAction)
  empresa   Empresa       @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
}

model GestionPago {
  id                 Int              @id @default(autoincrement())
  fecha              DateTime
  importeTotal       Decimal          @db.Decimal(18, 2)
  entidadId          Int
  asientoId          Int
  medioPagoId        Int
  observaciones      String?          @db.NVarChar(4000)
  anulado            Boolean          @default(false)
  fechaAnulacion     DateTime?
  asientoAnulacionId Int?
  empresaId          Int
  ejercicioId        Int
  createdAt          DateTime         @default(now(), map: "DF__GestionPa__creat__55BFB948")
  updatedAt          DateTime         @updatedAt
  createdBy          String?
  updatedBy          String?
  facturasDocentes   FacturaDocente[]
  asientoAnulacion   Asiento?         @relation("AsientoDeAnulacion", fields: [asientoAnulacionId], references: [id], onUpdate: NoAction)
  asiento            Asiento          @relation("AsientoDePago", fields: [asientoId], references: [id], onUpdate: NoAction)
  ejercicio          Ejercicio        @relation(fields: [ejercicioId], references: [id], onUpdate: NoAction)
  empresa            Empresa          @relation(fields: [empresaId], references: [id], onUpdate: NoAction)
  entidad            Entidad          @relation(fields: [entidadId], references: [id], onUpdate: NoAction)
  medioPago          MedioPago        @relation(fields: [medioPagoId], references: [id], onUpdate: NoAction)
}

model CentroCosto {
  id        Int                 @id @default(autoincrement())
  nombre    String
  empresaId Int
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  createdBy String?
  updatedBy String?
  cuentas   CentroCostoCuenta[]
  empresa   Empresa             @relation(fields: [empresaId], references: [id], onUpdate: NoAction)

  @@map("centros_costo")
}

model CentroCostoCuenta {
  centroCostoId Int
  cuentaId      Int
  centroCosto   CentroCosto @relation(fields: [centroCostoId], references: [id], onDelete: Cascade)
  cuenta        Cuenta      @relation(fields: [cuentaId], references: [id], onDelete: Cascade)

  @@id([centroCostoId, cuentaId])
  @@map("centro_costo_cuentas")
}

model Rubro {
  id                 Int                 @id @default(autoincrement())
  nombre             String              @unique
  activo             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  createdBy          String?
  updatedAt          DateTime            @updatedAt
  updatedBy          String?
  documentosClientes DocumentoClientes[]
  servicios          Servicio[]

  @@map("rubros")
}

model Departamento {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  createdBy String?
  updatedAt DateTime   @updatedAt
  updatedBy String?
  servicios Servicio[]

  @@map("departamentos")
}

model Servicio {
  id                     Int                 @id @default(autoincrement())
  nombre                 String              @unique
  activo                 Boolean             @default(true)
  rubroId                Int
  departamentoId         Int?
  participacionFundacion Boolean             @default(false)
  porcentajeFundacion    Decimal?            @db.Decimal(5, 2)
  participacionDepto     Boolean             @default(false)
  porcentajeDepto        Decimal?            @db.Decimal(5, 2)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  createdBy              String?
  updatedBy              String?
  documentosClientes     DocumentoClientes[]
  configs                ServicioConfig[]
  departamento           Departamento?       @relation(fields: [departamentoId], references: [id])
  rubro                  Rubro               @relation(fields: [rubroId], references: [id])

  @@map("servicios")
}

model ServicioConfig {
  id                       Int      @id @default(autoincrement())
  servicioId               Int
  empresaId                Int
  cuentaFundacionImputarId Int?
  cuentaFundacionRetenerId Int?
  cuentaDeptoImputarId     Int?
  cuentaDeptoRetenerId     Int?
  cuentaIngresosId         Int?
  createdAt                DateTime @default(now())
  createdBy                String?
  updatedAt                DateTime @updatedAt
  updatedBy                String?
  cuentaDeptoImputar       Cuenta?  @relation("CuentaDeptoImputar", fields: [cuentaDeptoImputarId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuentaDeptoRetener       Cuenta?  @relation("CuentaDeptoRetener", fields: [cuentaDeptoRetenerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuentaFundacionImputar   Cuenta?  @relation("CuentaFundacionImputar", fields: [cuentaFundacionImputarId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuentaFundacionRetener   Cuenta?  @relation("CuentaFundacionRetener", fields: [cuentaFundacionRetenerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cuentaIngresos           Cuenta?  @relation("CuentaIngresos", fields: [cuentaIngresosId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  empresa                  Empresa  @relation(fields: [empresaId], references: [id])
  servicio                 Servicio @relation(fields: [servicioId], references: [id])

  @@unique([servicioId, empresaId])
  @@map("servicio_configs")
}

/// Registro de auditoría para rastrear creaciones, modificaciones y eliminaciones
/// de entidades críticas del sistema contable.
model AuditLog {
  id          Int      @id @default(autoincrement())
  /// Nombre del modelo Prisma auditado (ej: "Cuenta", "Asiento", "FacturaDocente")
  entidad     String
  /// ID del registro afectado como string para soportar IDs numéricos y CUID
  entidadId   String
  /// Tipo de operación: "CREATE" | "UPDATE" | "DELETE"
  accion      String
  /// Snapshot JSON del estado ANTERIOR al cambio (null en CREATE)
  valoresAnt  String?  @db.NVarChar(Max)
  /// Snapshot JSON del estado NUEVO tras el cambio (null en DELETE)
  valoresNuev String?  @db.NVarChar(Max)
  /// Email o identificador del usuario que realizó el cambio
  cambiadoPor String?
  /// Timestamp del cambio (UTC)
  cambiadoEn  DateTime @default(now())
  /// Empresa a la que pertenece el registro — permite filtrar el historial por empresa
  empresaId   Int?

  @@index([entidad, entidadId])
  @@index([empresaId, cambiadoEn])
  @@index([cambiadoPor])
  @@map("audit_logs")
}
